# GMI MaaS (OpenAI-compatible) — for Gemini chat/vision
GMI_MAAS_BASE_URL=https://api.gmi-serving.com/v1
GMI_MAAS_API_KEY=
GMI_MODELS=google/gemini-3.5-flash

# GMI Inference Engine (image/video generation)
GMI_API_KEY=
GMI_IE_BASE_URL=https://console.gmicloud.ai/api/v1/ie/requestqueue/apikey
IMAGE_GENERATE_MODEL_ID=gpt-image-2-generate
IMAGE_EDIT_MODEL_ID=gpt-image-2-edit
VIDEO_MODEL_ID=kling-v3-image-to-video

# Web search (optional)
TAVILY_API_KEY=

# Observability
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agent-visual-manual

# Storage
ARTIFACT_PUBLIC_BASE_URL=
ARTIFACT_BUCKET=
UPLOAD_DIR=

# Runtime
MAX_VIDEO_WAIT_SEC=300
FRAME_COUNT=24

# Database (optional, for persistent jobs)
DATABASE_URL=
REDIS_URL=
