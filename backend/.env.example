# GMI Cloud — all models routed through the OpenAI-compatible gateway.
GMI_API_KEY=
GMI_BASE_URL=https://api.gmi-serving.com/v1

# Model IDs — use the EXACT strings from the GMI Model Library.
GMI_CHAT_MODEL=google/gemini-3.5-flash        # 3.5 Flash — agent brain (chat + action protocol)
GMI_IMAGE_MODEL=gpt-image-2-edit       # GPT-Image-2-Edit — part image + multi-angle shots (2D path)
GMI_VIDEO_MODEL=kling-v3-omni       # Kling V3 Omni — 3D physics explode + turntable (1080p pro mode)

# Async request-queue host for media models (image + video). Chat uses GMI_BASE_URL.
GMI_REQUEST_QUEUE_URL=https://console.gmicloud.ai/api/v1/ie/requestqueue/apikey

# 2D pipeline tuning (optional)
GMI_2D_DURATION=5      # Kling clip length, seconds (3–15)
GMI_2D_ANGLES=1        # how many part/multi-angle shots to generate
# GMI_2D_IMAGE_PROMPT=...   # override the part-render prompt
# GMI_2D_VIDEO_PROMPT=...   # override the exploded-view motion prompt

# 3D path (kept for the 3D demo; may be unavailable on GMI):
PARTCRAFTER_URL=       # PartCrafter endpoint — image -> separated parts
MESHY_API_KEY=         # fallback single-mesh generator

# CORS: comma-separated origins allowed to call this backend.
# Vercel preview deploys (*.vercel.app) are allowed by regex in main.py.
CORS_ORIGINS=http://localhost:3000
